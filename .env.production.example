# ──────────────────────────────────────────────────────────────────────────
# BYOS PRODUCTION environment (template).
#
# Set these as environment variables on your deploy platform (Railway / Render /
# Fly.io / etc.). Do NOT commit real values. Dev uses apps/api/.env (local
# Postgres); this file is only for production.
#
# PERFORMANCE RULE: host the DB and the API in the SAME region (Neon Singapore
# + API on a Singapore region) so API↔DB round-trips are ~1ms. That is what
# makes login/queries fast for a globe-crossing DB.
# ──────────────────────────────────────────────────────────────────────────

ENVIRONMENT=production

# ── PostgreSQL (Neon, AWS ap-southeast-1 Singapore) ──────────────────────────
# From Neon → Connection string. The app auto-converts to the asyncpg driver
# and handles sslmode / the -pooler endpoint, so paste it as given.
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<endpoint>.ap-southeast-1.aws.neon.tech/<db>?sslmode=require

# ── Redis (managed — e.g. Upstash, in/near the same region) ──────────────────
REDIS_URL=rediss://<user>:<password>@<host>:<port>

# ── App auth (JWT) — generate STRONG secrets for production ──────────────────
# python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=<generate-a-strong-secret>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
REFRESH_COOKIE_NAME=byos_refresh
# MUST be true in production (cookies only sent over HTTPS).
REFRESH_COOKIE_SECURE=true

# ── Provider-credential encryption (Fernet) ──────────────────────────────────
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep this stable — rotating it makes existing encrypted Telegram sessions unreadable.
BYOS_ENCRYPTION_KEY=<generate-a-real-fernet-key>

# ── Telegram (same app credentials as dev) ───────────────────────────────────
TELEGRAM_API_ID=<your-api-id>
TELEGRAM_API_HASH=<your-api-hash>

# ── CORS / URLs (your real domains) ──────────────────────────────────────────
CORS_ORIGINS=https://app.yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
INTERNAL_API_URL=https://api.yourdomain.com
