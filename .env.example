# ──────────────────────────────────────────────────────────────────────────
# BYOS environment — copy to `.env` and fill in. Docker Compose reads this file.
# ──────────────────────────────────────────────────────────────────────────

ENVIRONMENT=development

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=byos
POSTGRES_PASSWORD=byos
POSTGRES_DB=byos
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Async SQLAlchemy URL used by the API (asyncpg driver).
DATABASE_URL=postgresql+asyncpg://byos:byos@postgres:5432/byos

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── App auth (JWT) ────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-dev-only-do-not-use-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
REFRESH_COOKIE_NAME=byos_refresh
# Set true behind HTTPS in production.
REFRESH_COOKIE_SECURE=false

# ── Provider-credential encryption (Fernet master key) ───────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BYOS_ENCRYPTION_KEY=change-me-generate-a-real-fernet-key

# ── Telegram (Phase 2 — register an app at https://my.telegram.org) ──────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ── CORS / URLs ──────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call the API (the web app).
CORS_ORIGINS=http://localhost:3000

# ── Web (Next.js) ─────────────────────────────────────────────────────────────
# Browser-visible API base URL.
NEXT_PUBLIC_API_URL=http://localhost:8000
# Server-side (SSR / route handlers) API base URL — inside Docker network use the service name.
INTERNAL_API_URL=http://api:8000
